# Application Configuration
PORT=5000
NODE_ENV=development
API_VERSION=v1
FRONTEND_URL=http://localhost:3000

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/db_name?schema=public

# Redis Configuration (Caching & Token Blacklist)
REDIS_URL=redis://localhost:6379

# JWT Configurations
JWT_ACCESS_SECRET=your_super_secret_access_token_signing_key_at_least_32_bytes
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_token_signing_key_at_least_32_bytes
JWT_REFRESH_EXPIRY=7d

# SMTP Configuration (Email Service)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM="SaaS Platform Auth" <noreply@saasplatform.com>

# Security Configs
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
COOKIES_SECURE=true
